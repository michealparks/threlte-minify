{
	"name": "threlte-minify",
	"version": "0.0.2",
	"description": "A Vite plugin that reduces bundle size for Threlte and Three.js applications through deep tree-shaking and minification.",
	"keywords": [
		"vite",
		"vite-plugin",
		"threlte",
		"three",
		"threejs",
		"three.js",
		"svelte",
		"minify",
		"tree-shaking",
		"bundle-size",
		"optimization",
		"3d",
		"webgl"
	],
	"homepage": "https://github.com/michealparks/threlte-minify#readme",
	"repository": {
		"type": "git",
		"url": "https://github.com/michealparks/threlte-minify.git"
	},
	"bugs": {
		"url": "https://github.com/michealparks/threlte-minify/issues"
	},
	"license": "MIT",
	"sideEffects": false,
	"author": {
		"name": "Micheal Parks",
		"email": "michealparks1989@gmail.com",
		"url": "https://parks.lol"
	},
	"engines": {
		"node": ">=18"
	},
	"exports": {
		"import": "./plugin/index.js",
		"types": "./plugin/index.d.ts"
	},
	"files": [
		"./plugin/*"
	],
	"scripts": {
		"dev": "vite dev --host",
		"build": "vite build",
		"build:null": "vite build --mode null",
		"build:threlte": "vite build --mode threlte",
		"build:three": "vite build --mode three",
		"preview": "vite preview",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write . && eslint . --fix",
		"stats": "node stats.js",
		"test": "vitest",
		"test:watch": "vitest --watch"
	},
	"devDependencies": {
		"@changesets/cli": "^2.30.0",
		"@eslint/js": "^10.0.1",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/kit": "^2.55.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@threlte/core": "^8.5.5",
		"@threlte/extras": "^9.14.2",
		"@types/three": "^0.183.1",
		"@yushijinhun/three-minifier-rollup": "^0.4.0",
		"eslint": "^10.1.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-perfectionist": "^5.8.0",
		"eslint-plugin-svelte": "^3.17.0",
		"globals": "^17.4.0",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"svelte": "^5.55.1",
		"svelte-check": "^4.4.6",
		"three": "^0.183.2",
		"typescript": "^6.0.2",
		"typescript-eslint": "^8.58.0",
		"vite": "^8.0.3",
		"vitest": "^4.1.2"
	},
	"peerDependencies": {
		"vite": ">=5.0.0"
	},
	"dependencies": {
		"magic-string": "^0.30.21"
	},
	"type": "module",
	"packageManager": "pnpm@10.33.0"
}
